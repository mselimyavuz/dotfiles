/* default window size: width, height */
static int winsize[] = { 1200, 800 };

static WebKitFindOptions findopts = WEBKIT_FIND_OPTIONS_CASE_INSENSITIVE |
                                    WEBKIT_FIND_OPTIONS_WRAP_AROUND;

#define PROMPT_GO   "Go:"
#define PROMPT_FIND "Find:"

/* Gruvbox Dark Colors for dmenu */
#define GB_BG "#282828"
#define GB_FG "#ebdbb2"
#define GB_SEL_BG "#d65d0e"
#define GB_SEL_FG "#fbf1c7"

/* SETPROP(readprop, setprop, prompt)*/
#define SETPROP(r, s, p) { \
        .v = (const char *[]){ "/bin/sh", "-c", \
             "prop=\"$(printf '%b' \"$(xprop -id $1 $2 " \
             "| sed \"s/^$2(STRING) = //;s/^\\\"\\(.*\\)\\\"$/\\1/\")\" " \
             "| dmenu -nb '"GB_BG"' -nf '"GB_FG"' -sb '"GB_SEL_BG"' -sf '"GB_SEL_FG"' -p \"$4\" -w $1)\" && xprop -id $1 -f $3 8s -set $3 \"$prop\"", \
             "surf-setprop", winid, r, s, p, NULL \
        } \
}

/* Bitwarden-CLI Integration */
/* Requires: bw, xdotool, jq */
#define BITWARDEN { \
    .v = (const char *[]){ "/bin/sh", "-c", \
        "bw unlock --check || export BW_SESSION=$(bw unlock --raw); " \
        "item=$(bw list items | jq -r '.[] | .name' | dmenu -nb '"GB_BG"' -nf '"GB_FG"' -sb '"GB_SEL_BG"' -sf '"GB_SEL_FG"' -p 'Bitwarden:'); " \
        "bw get password \"$item\" | xdotool type --clearmodifiers --file -", \
        NULL \
    } \
}

/* DOWNLOAD(URI, referer) */
#define DOWNLOAD(u, r) { \
        .v = (const char *[]){ "st", "-e", "/bin/sh", "-c",\
             "curl -g -L -J -O -A \"$1\" -b \"$2\" -c \"$2\"" \
             " -e \"$3\" \"$4\"; read", \
             "surf-download", useragent, cookiefile, r, u, NULL \
        } \
}

#define PLUMB(u) { .v = (const char *[]){ "/bin/sh", "-c", "xdg-open \"$0\"", u, NULL } }
#define VIDEOPLAY(u) { .v = (const char *[]){ "/bin/sh", "-c", "mpv --really-quiet \"$0\"", u, NULL } }

