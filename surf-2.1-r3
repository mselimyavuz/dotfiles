    { MODKEY,                GDK_KEY_slash,  spawn,          SETPROP("_SURF_FIND", "_SURF_FIND", PROMPT_FIND) },
    { MODKEY,                GDK_KEY_w,      spawn,          BITWARDEN },

    { 0,                     GDK_KEY_Escape, stop,           { 0 } },
